      /* ---------- why ---------- */
      .why-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
      @media (min-width: 620px) { .why-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 900px) { .why-grid { grid-template-columns: repeat(3, 1fr); } }
      .why-item { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px; font-weight: 500; }
      .why-item span { display: grid; place-items: center; width: 26px; height: 26px; flex: none; border-radius: 50%; background: var(--accent-soft); color: var(--accent-ink); font-size: 0.85rem; }

      /* ---------- final cta ---------- */
      .final-inner { background: var(--ink); color: #fff; border-radius: var(--radius-lg); padding: 48px 28px; text-align: center; position: relative; overflow: hidden; }
      .final-inner::before { content: '◍ ▣ ✦ ◍ ▣ ✦'; position: absolute; top: 12px; left: 0; right: 0; text-align: center; font-family: var(--font-mono); font-size: 0.8rem; color: rgba(255,255,255,0.12); letter-spacing: 0.5em; }
      .final-inner h2 { font-size: clamp(1.6rem, 4.5vw, 2.4rem); margin-bottom: 12px; }
      .final-inner p { color: rgba(255,255,255,0.8); max-width: 48ch; margin: 0 auto 24px; }

      /* ---------- faq ---------- */
      .narrow { max-width: 760px; }
      .faq-list { display: grid; gap: 10px; }
      .faq-item { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 4px 20px; }
      .faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 12px; cursor: pointer; list-style: none; padding: 16px 0; font-weight: 600; }
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-plus { transition: transform .2s ease; color: var(--accent); font-size: 1.2rem; }
      .faq-item[open] .faq-plus { transform: rotate(45deg); }
      .faq-item p { margin: 0 0 18px; color: var(--ink-soft); }

      /* ---------- footer ---------- */
      .site-footer { border-top: 1px solid var(--line); background: #fff; padding: 40px 0 28px; margin-top: 20px; }
      .footer-inner { display: grid; gap: 24px; }
      @media (min-width: 720px) { .footer-inner { grid-template-columns: 1fr auto; align-items: center; } }
      .footer-brand strong { font-size: 1.05rem; }
      .footer-brand p { color: var(--muted); margin: 6px 0 0; font-size: 0.9rem; }
      .footer-nav { display: flex; flex-wrap: wrap; gap: 18px; }
      .footer-nav a { text-decoration: none; color: var(--ink-soft); font-size: 0.95rem; }
      .footer-nav a:hover { color: var(--ink); }
      .footer-legal { margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--line); }
      .footer-legal p { color: var(--muted); font-size: 0.8rem; margin: 0; }
    </style>
